# Copie este arquivo para .env e preencha os valores

# Django
SECRET_KEY=coloque-uma-chave-secreta-forte-aqui
DEBUG=False
ALLOWED_HOSTS=seu-backend.onrender.com

# Banco de dados (Supabase)
# Use a URL do Session Pooler (porta 5432) no painel do Supabase > Settings > Database
DATABASE_URL=postgresql://postgres.XXXX:SENHA@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# CORS — URL do seu frontend no Render
FRONTEND_URL=https://seu-frontend.onrender.com

# CSRF — mesma URL do frontend (e do backend)
CSRF_TRUSTED_ORIGINS=https://seu-frontend.onrender.com,https://seu-backend.onrender.com
